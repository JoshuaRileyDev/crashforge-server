PORT=3000
DATA_DIR=./data
# Used by local non-Docker runs (npm run dev):
DATABASE_URL=postgres://crash:crash@127.0.0.1:56432/crash_reporter
# Used by Docker Compose server container (optional override):
# APP_DATABASE_URL=postgres://crash:crash@postgres:5432/crash_reporter
WEBHOOK_URL=https://example.com/webhooks/crashes
WEBHOOK_AUTH_HEADER=Bearer replace-me
GITHUB_TOKEN=ghp_replace_me_for_private_repos
